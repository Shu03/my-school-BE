{
    "compilerOptions": {
        "module": "commonjs",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2021",
        "sourceMap": true,
        "outDir": "./dist",
        "baseUrl": "./src",
        "rootDir": "./src",
        "incremental": true,
        "tsBuildInfoFile": "./dist/tsconfig.build.tsbuildinfo",
        "skipLibCheck": true,
        "strictNullChecks": true,
        "noImplicitAny": true,
        "strictBindCallApply": true,
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "paths": {
            "@common/*": ["common/*"],
            "@config/*": ["config/*"],
            "@modules/*": ["modules/*"]
        }
    },
    "exclude": [
        "node_modules",
        "dist",
        "prisma"
    ]
}